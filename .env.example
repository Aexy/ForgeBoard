## Forgeboard Database variables
DB_URL=jdbc:postgresql://localhost:5432/forgeboard
DB_USER=forgeboard
DB_PASSWORD="your-password-here"

# Dedicated-host Next preview deployment. Supply real production values through
# your secret store or an external Compose env file; never commit that file.
AUTH_SECRET="replace-with-a-long-random-secret"
FORGEBOARD_TOKEN_ISSUER=forgeboard
FORGEBOARD_PREVIEW_FIRM_SLUGS=pilot-accounting
NEXT_PREVIEW_HOST=next-preview.example.com
FORGEBOARD_API_BASE_URL=http://forgeboard-api.internal:8080
FORGEBOARD_BACKEND_NETWORK=forgeboard-internal
ACME_EMAIL=ops@example.com
