# Local-only configuration for `pnpm web:e2e`.
# Copy this file to e2e.env and replace placeholder values. Never commit e2e.env.
DB_URL=jdbc:postgresql://localhost:5432/test_database
DB_USER=test_user
DB_PASSWORD=replace-with-the-test_user-password

#The port for the backend
APP_PORT=8081

# Use a different development-only secret from the one in .env. It must be Base64 for at least 32 random bytes.
FORGEBOARD_API_TOKEN_SECRET=replace-with-a-random-base64-test-secret
