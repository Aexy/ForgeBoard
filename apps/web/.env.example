# Runtime-only values. Set these in the deployment secret/configuration store; do not bake real values into an image.
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=https://next-preview.example.com
FORGEBOARD_API_BASE_URL=http://forgeboard-api:8080
FORGEBOARD_TOKEN_ISSUER=forgeboard
FORGEBOARD_PUBLIC_ORIGIN=https://next-preview.example.com
# Comma-separated, server-only rollout selector. Production requires at least one firm slug.
FORGEBOARD_PREVIEW_FIRM_SLUGS=pilot-accounting
